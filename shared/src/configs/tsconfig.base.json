{
  "compilerOptions": {
    "target": "ES2022",

    "module": "NodeNext",

    "moduleResolution": "NodeNext",

    "strict": true,

    "isolatedModules": true,

    "esModuleInterop": true,

    "allowSyntheticDefaultImports": true,

    "resolveJsonModule": true,

    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "sourceMap": true,

    "declaration": true,

    "types": ["node"],

    "outDir": "dist"
  },

  "exclude": ["node_modules", "dist", "coverage"]
}
